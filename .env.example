# 服务器配置
PORT=3001
HOST=localhost

# 数据库
DATABASE_PATH=./data/forum.db

# Session 密钥（生产环境请更换）
SESSION_SECRET=change-me-in-production

# 前端地址（CORS）
CLIENT_URL=http://localhost:5173

# GitHub OAuth（用于第三方登录）
# 在 https://github.com/settings/developers 创建 OAuth App
# Homepage URL: http://localhost:3001
# Authorization callback URL: http://localhost:3001/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# QQ OAuth
# 在 https://connect.qq.com 创建应用
# 回调地址: http://localhost:3001/api/auth/oauth/qq/callback
QQ_CLIENT_ID=
QQ_CLIENT_SECRET=

# 微信 OAuth（开放平台）
# 在 https://open.weixin.qq.com 创建网站应用
# 回调地址: http://localhost:3001/api/auth/oauth/weixin/callback
WEIXIN_CLIENT_ID=
WEIXIN_CLIENT_SECRET=
